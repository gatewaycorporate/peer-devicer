{
  "name": "peer-devicer",
  "version": "0.1.3",
  "type": "module",
  "description": "Peer Reputation Networking Middleware for the FP-Devicer Intelligence Suite",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js",
      "default": "./dist/main.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --outDir dist",
    "test": "npx vitest run",
    "test:watch": "npx vitest watch",
    "test:coverage": "npx vitest run --coverage",
    "docs": "typedoc --out docs src/main.ts",
    "docs:watch": "typedoc --out docs src/main.ts --watch"
  },
  "keywords": [
    "peer",
    "reputation",
    "graph",
    "fingerprinting",
    "middleware",
    "bot-detection"
  ],
  "author": "Samuel Roux",
  "license": "BSL-1.0",
  "dependencies": {
    "devicer.js": "^2.0.2",
    "ipaddr.js": "^2.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^18.15.11",
    "@types/pg": "^8.18.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typedoc": "^0.28.17",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "better-sqlite3": "^12.6.2",
    "ioredis": "^5.10.0",
    "pg": "^8.20.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  }
}
